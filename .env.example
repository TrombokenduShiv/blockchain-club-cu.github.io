# Google Service Account Credentials
# Create a Service Account in Google Cloud, enable Google Sheets API, 
# and share your Target Spreadsheet with this email address as an "Editor".

GOOGLE_CLIENT_EMAIL="your-service-account-email@project-id.iam.gserviceaccount.com"

# Important: Make sure the final key string maintains the \n characters or is properly quoted
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
